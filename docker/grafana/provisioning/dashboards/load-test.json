{
  "description": "Notification Dispatcher 부하테스트 모니터링",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "panels": [
    {
      "collapsed": false,
      "id": 100,
      "title": "Application - CPU / Memory",
      "type": "row",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      }
    },
    {
      "id": 1,
      "type": "timeseries",
      "title": "CPU Usage",
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": {
            "lineWidth": 2
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "expr": "process_cpu_usage{application=\"notification-dispatcher\"}",
          "legendFormat": "Process CPU"
        },
        {
          "expr": "system_cpu_usage{application=\"notification-dispatcher\"}",
          "legendFormat": "System CPU"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "JVM Memory (Heap)",
      "gridPos": {
        "x": 12,
        "y": 1,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "lineWidth": 2
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{application=\"notification-dispatcher\", area=\"heap\"}",
          "legendFormat": "Heap Used"
        },
        {
          "expr": "jvm_memory_committed_bytes{application=\"notification-dispatcher\", area=\"heap\"}",
          "legendFormat": "Heap Committed"
        },
        {
          "expr": "jvm_memory_max_bytes{application=\"notification-dispatcher\", area=\"heap\"}",
          "legendFormat": "Heap Max"
        }
      ]
    },
    {
      "collapsed": false,
      "id": 101,
      "title": "Application - GC",
      "type": "row",
      "gridPos": {
        "x": 0,
        "y": 9,
        "w": 24,
        "h": 1
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Full GC Count (누적)",
      "description": "Major GC (Full GC) 누적 횟수. 부하 중 증가하면 Heap 크기 또는 메모리 누수 의심",
      "gridPos": {
        "x": 0,
        "y": 10,
        "w": 6,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 3
              },
              {
                "color": "red",
                "value": 10
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "sum(jvm_gc_pause_seconds_count{application=\"notification-dispatcher\", action=~\".*major.*\"}) or vector(0)",
          "legendFormat": "Full GC"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Minor GC Count (누적)",
      "gridPos": {
        "x": 6,
        "y": 10,
        "w": 6,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 50
              },
              {
                "color": "red",
                "value": 200
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "sum(jvm_gc_pause_seconds_count{application=\"notification-dispatcher\", action=~\".*minor.*\"})",
          "legendFormat": "Minor GC"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "GC Max Pause Time",
      "description": "100ms 이상이면 응답시간에 영향, 500ms 이상이면 심각",
      "gridPos": {
        "x": 12,
        "y": 10,
        "w": 6,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.1
              },
              {
                "color": "red",
                "value": 0.5
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "jvm_gc_pause_seconds_max{application=\"notification-dispatcher\"}",
          "legendFormat": "Max Pause"
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Live Data Size (Old Gen)",
      "description": "GC 후 살아남은 Old Gen 크기. 계속 증가하면 메모리 누수 의심",
      "gridPos": {
        "x": 18,
        "y": 10,
        "w": 6,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 268435456
              },
              {
                "color": "red",
                "value": 536870912
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "jvm_gc_live_data_size_bytes{application=\"notification-dispatcher\"}",
          "legendFormat": "Live Data Size"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "GC Count Rate (per minute)",
      "description": "분당 GC 발생 횟수. Full GC가 반복되면 Heap 튜닝 필요",
      "gridPos": {
        "x": 0,
        "y": 14,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "expr": "(rate(jvm_gc_pause_seconds_count{application=\"notification-dispatcher\", action=~\".*major.*\"}[1m]) or vector(0)) * 60",
          "legendFormat": "Full GC / min"
        },
        {
          "expr": "rate(jvm_gc_pause_seconds_count{application=\"notification-dispatcher\", action=~\".*minor.*\"}[1m]) * 60",
          "legendFormat": "Minor GC / min"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "GC Pause Duration",
      "description": "GC STW(Stop-The-World) 정지 시간. 응답시간 스파이크와 연관성 확인",
      "gridPos": {
        "x": 12,
        "y": 14,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 2
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "expr": "rate(jvm_gc_pause_seconds_sum{application=\"notification-dispatcher\"}[1m]) / rate(jvm_gc_pause_seconds_count{application=\"notification-dispatcher\"}[1m])",
          "legendFormat": "GC Avg Pause"
        },
        {
          "expr": "jvm_gc_pause_seconds_max{application=\"notification-dispatcher\"}",
          "legendFormat": "GC Max Pause ({{action}})"
        }
      ]
    },
    {
      "collapsed": false,
      "id": 102,
      "title": "Application - HTTP 응답시간",
      "type": "row",
      "gridPos": {
        "x": 0,
        "y": 22,
        "w": 24,
        "h": 1
      }
    },
    {
      "id": 18,
      "type": "stat",
      "title": "TPS",
      "gridPos": {
        "x": 0,
        "y": 23,
        "w": 5,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": {
            "fixedColor": "blue",
            "mode": "fixed"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area"
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"notification-dispatcher\"}[1m]))",
          "legendFormat": "TPS"
        }
      ]
    },
    {
      "id": 22,
      "type": "stat",
      "title": "Peak TPS",
      "description": "테스트 구간 내 최고 TPS (최근 30분)",
      "gridPos": {
        "x": 5,
        "y": 23,
        "w": 5,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 1,
          "color": {
            "fixedColor": "blue",
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "max_over_time(sum(rate(http_server_requests_seconds_count{application=\"notification-dispatcher\"}[1m]))[30m:1m])",
          "legendFormat": "Peak TPS"
        }
      ]
    },
    {
      "id": 19,
      "type": "stat",
      "title": "P95 응답시간",
      "gridPos": {
        "x": 10,
        "y": 23,
        "w": 4,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.3
              },
              {
                "color": "red",
                "value": 0.5
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
