    {
      "collapsed": false,
      "id": 103,
      "title": "DB - MySQL",
      "type": "row",
      "gridPos": {
        "x": 0,
        "y": 43,
        "w": 24,
        "h": 1
      }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "MySQL Active Threads (DB 부하)",
      "description": "threads_running = 현재 실행 중인 쿼리 수. CPU 부하의 proxy 지표. threads_connected = 전체 연결 수",
      "gridPos": {
        "x": 0,
        "y": 44,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "expr": "mysql_global_status_threads_running",
          "legendFormat": "Threads Running (Active)"
        },
        {
          "expr": "mysql_global_status_threads_connected",
          "legendFormat": "Threads Connected"
        },
        {
          "expr": "mysql_global_variables_max_connections",
          "legendFormat": "Max Connections"
        }
      ]
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "MySQL Query Rate",
      "description": "초당 쿼리 수 및 슬로우 쿼리 발생률",
