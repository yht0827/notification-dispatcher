    {
      "id": 10,
      "type": "timeseries",
      "title": "HTTP Request Rate & Error Rate",
      "gridPos": {
        "x": 12,
        "y": 27,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Error Rate"
            },
            "properties": [
              {
                "id": "unit",
                "value": "percentunit"
              },
              {
                "id": "custom.axisPlacement",
                "value": "right"
              }
            ]
          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"notification-dispatcher\"}[1m]))",
          "legendFormat": "Total RPS"
        },
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"notification-dispatcher\", status=~\"5..\"}[1m]))",
          "legendFormat": "5xx RPS"
        },
        {
          "expr": "(sum(rate(http_server_requests_seconds_count{application=\"notification-dispatcher\", status=~\"5..\"}[1m])) or vector(0)) / sum(rate(http_server_requests_seconds_count{application=\"notification-dispatcher\"}[1m]))",
          "legendFormat": "Error Rate"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "HTTP Response Time by URI (P95)",
      "gridPos": {
        "x": 0,
        "y": 35,
        "w": 24,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 2
          }
        },
        "overrides": []
      },
