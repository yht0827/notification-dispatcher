          "calcs": [
            "mean",
            "max",
            "last"
          ]
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=\"notification-dispatcher\"}[1m])) by (le, uri, method))",
          "legendFormat": "{{method}} {{uri}}"
        }
      ]
