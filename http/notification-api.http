### 실행 환경 변수
@host = http://localhost:8080
@contentType = application/json
@groupId = 1
@notificationId = 1

### ==================================================
### 1) 알림 발송
### ==================================================

### 단일 알림 발송 (멱등 키 포함)
# @name send_single_notification
POST {{host}}/api/v1/notifications
Content-Type: {{contentType}}

{
  "clientId": "order-service",
  "sender": "MyShop",
  "title": "주문 완료",
  "content": "주문이 완료되었습니다. 주문번호: #12345",
  "channelType": "EMAIL",
  "receivers": ["user@example.com"],
  "idempotencyKey": "order-12345"
}

### 대량 알림 발송
# @name send_bulk_notification
POST {{host}}/api/v1/notifications
Content-Type: {{contentType}}

{
  "clientId": "marketing-service",
  "sender": "MyShop",
  "title": "신규 프로모션 안내",
  "content": "지금 가입하시면 20% 할인!",
  "channelType": "EMAIL",
  "receivers": [
    "user1@example.com",
    "user2@example.com",
    "user3@example.com"
  ],
  "idempotencyKey": "marketing-campaign-20260223"
}

### 카카오 알림 발송
POST {{host}}/api/v1/notifications
Content-Type: {{contentType}}

{
  "clientId": "payment-service",
  "sender": "MyShop",
  "title": "결제 완료",
  "content": "10,000원이 결제되었습니다.",
  "channelType": "KAKAO",
  "receivers": ["kakao_user_123"],
  "idempotencyKey": "payment-10000"
}

### SMS 알림 발송
POST {{host}}/api/v1/notifications
Content-Type: {{contentType}}

{
  "clientId": "delivery-service",
  "sender": "MyShop",
  "title": "배송 시작",
  "content": "상품이 배송을 시작했습니다.",
  "channelType": "SMS",
  "receivers": ["010-1234-5678"],
  "idempotencyKey": "delivery-12345"
}

### ==================================================
### 2) 알림 그룹 조회
### ==================================================

### 알림 묶음 목록 조회 (대표 알림 + moreCount)
GET {{host}}/api/v1/notifications

### 그룹 상세 조회 (groupId 기준)
GET {{host}}/api/v1/notifications/groups/{{groupId}}

### clientId로 그룹 목록 조회
GET {{host}}/api/v1/notifications/groups?clientId=marketing-service

### ==================================================
### 3) 개별 알림 조회
### ==================================================

### 알림 ID 조회
GET {{host}}/api/v1/notifications/{{notificationId}}

### 수신자로 알림 목록 조회
GET {{host}}/api/v1/notifications?receiver=user@example.com

### ==================================================
### 4) 오류 케이스
### ==================================================

### 필수 필드 누락 (400 잘못된 요청)
POST {{host}}/api/v1/notifications
Content-Type: {{contentType}}

{
  "clientId": "order-service",
  "sender": "MyShop"
}

### receiver 값이 비어있는 경우 (예상: 400 잘못된 요청)
GET {{host}}/api/v1/notifications?receiver=

### clientId 값이 비어있는 경우 (예상: 400 잘못된 요청)
GET {{host}}/api/v1/notifications/groups?clientId=

### 존재하지 않는 그룹 조회 (404 리소스 없음)
GET {{host}}/api/v1/notifications/groups/99999

### 존재하지 않는 알림 조회 (404 리소스 없음)
GET {{host}}/api/v1/notifications/99999
